# .env.example
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is in .gitignore.
#
# SEC-02 ENFORCED: No secret variable uses the NEXT_PUBLIC_ prefix.
# NEXT_PUBLIC_ variables are embedded in the browser bundle by Next.js.
# All variables below are server-only by default.

# ── Demo Mode ────────────────────────────────────────────────────────────
# Set to "true" for the public portfolio/demo deployment.
# Effects: all outbound emails are suppressed (logged to console instead),
# Resend vars (RESEND_API_KEY, RESEND_FROM, ADMIN_EMAILS) become optional,
# and the admin login page displays the password as a visible hint.
# Leave unset (or set to "false") for the production deployment.
DEMO_MODE=false

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service role key from: Supabase Dashboard → Project Settings → API
# WARNING: This key bypasses Row Level Security. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Email Domain Allowlist ────────────────────────────────────────────────
# Comma-separated list of domains permitted to submit a request.
# Example: schoolname.org,schoolname.edu
#
# Matching semantics (FAIL-CLOSED):
#   - Exact domain match only — foo@mail.schoolname.org does NOT match schoolname.org.
#     (To allow subdomain access, add `mail.schoolname.org` explicitly.)
#   - Case-insensitive — Teacher@SCHOOL.ORG matches school.org.
#   - Empty value (unset or "") rejects ALL emails. This is intentional:
#     a missing allowlist is treated as "no one is allowed", not "everyone is allowed".
#
# Bypass: when DEMO_MODE=true the allowlist is not enforced (the demo flow
# accepts any email so portfolio reviewers can submit without setup).
#
# Note: the form has no upfront login (small trusted user base — see the
# revert commit for the magic-link auth that was removed). This server-side
# check is the only authoritative gate on submitted emails.
ALLOWED_EMAIL_DOMAINS=schoolname.edu

# Browser-facing hint for the email field's onBlur validation (UX only).
# Comma-separated. Same values as ALLOWED_EMAIL_DOMAINS but exposed to the
# browser bundle, so the form can show an inline "this system is only for
# @schoolname.edu emails" message before the user submits.
#
# NOT a security control — anyone can edit the bundled JS or POST directly.
# The server-side ALLOWED_EMAIL_DOMAINS check above is the authoritative gate.
# If you forget to set this, the form just skips the client-side hint and
# falls back to the server response on submit.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS_HINT=schoolname.edu

# ── Resend (Email) ────────────────────────────────────────────────────────
# API key from: resend.com → API Keys
RESEND_API_KEY=re_...

# Admin email address(es) that receive leave request notifications.
# Comma-separated for multiple recipients: admin@school.edu,principal@school.edu
ADMIN_EMAILS=admin@school.edu

# The "from" address for outbound emails. Must be a verified Resend domain.
RESEND_FROM=Time Off System <noreply@yourdomain.com>

# ── Resend Pre-Launch Checklist ──────────────────────────────────────────
# Before going live, verify your sending domain in Resend so emails reach
# inboxes reliably and pass spam filters.
#
# 1. Log in to resend.com → Domains → Add Domain
# 2. Add the SPF record at your domain registrar:
#    Type: TXT  Host: @  Value: v=spf1 include:_spf.resend.com ~all
# 3. Add the DKIM record at your domain registrar:
#    Type: TXT  Host: resend._domainkey  Value: (provided by Resend dashboard)
# 4. Click "Verify" in the Resend dashboard — status must show "Verified"
# 5. Send a test email via Resend and confirm it arrives in your inbox (not spam)
#
# Domain verification is required; emails from unverified domains are
# likely to be flagged as spam or rejected outright.

# ── Approval Workflow ────────────────────────────────────────────────────
# HMAC secret for per-request approval tokens (SEC-02).
# Each admin approve/deny URL receives a unique HMAC-SHA256 token scoped to that
# request ID and action. A token for "approve" on request A cannot be reused to
# deny request A or to approve/deny any other request.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APPROVAL_HMAC_SECRET=

# Legacy: APPROVAL_SECRET is superseded by APPROVAL_HMAC_SECRET (SEC-02).
# Kept for reference during migration — remove after verifying APPROVAL_HMAC_SECRET is set.
APPROVAL_SECRET=

# How long (in days) an approval link remains valid after the email is sent.
# Default is 7. Tokens include this expiry in their HMAC payload, so changing the
# value affects newly-issued links only — links already in admin inboxes keep their
# original expiry. Set to a small integer (1-30); invalid values silently fall back to 7.
APPROVAL_LINK_EXPIRY_DAYS=7

# Public base URL for approval link generation in admin notification emails.
# Set to your Vercel deployment URL in production (e.g. https://your-app.vercel.app).
# For local development: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Admin Dashboard ──────────────────────────────────────────────────────
# Password for the admin dashboard login page (production deployment).
# Required when DEMO_MODE is unset or false. Must be kept SECRET — never
# share this with anyone who shouldn't be approving leave requests.
ADMIN_PASSWORD=

# Password for the admin dashboard login page (demo deployment only).
# Required when DEMO_MODE=true. Kept distinct from ADMIN_PASSWORD so the
# demo deployment can never expose production credentials — the demo login
# page openly displays this value as a hint to portfolio reviewers, so it
# MUST NOT match ADMIN_PASSWORD.
DEMO_ADMIN_PASSWORD=demo2026

# Secret for encrypting the admin session cookie (iron-session).
# MUST be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
