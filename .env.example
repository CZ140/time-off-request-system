# .env.example
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is in .gitignore.
#
# SEC-02 ENFORCED: No secret variable uses the NEXT_PUBLIC_ prefix.
# NEXT_PUBLIC_ variables are embedded in the browser bundle by Next.js.
# All variables below are server-only by default.

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service role key from: Supabase Dashboard → Project Settings → API
# WARNING: This key bypasses Row Level Security. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (Email) ────────────────────────────────────────────────────────
# API key from: resend.com → API Keys
RESEND_API_KEY=re_...

# Admin email address(es) that receive leave request notifications.
# Comma-separated for multiple recipients: admin@school.edu,principal@school.edu
ADMIN_EMAILS=admin@school.edu

# The "from" address for outbound emails. Must be a verified Resend domain.
RESEND_FROM=Time Off System <noreply@yourdomain.com>

# ── Resend Pre-Launch Checklist ──────────────────────────────────────────
# Before going live, verify your sending domain in Resend so emails reach
# inboxes reliably and pass spam filters.
#
# 1. Log in to resend.com → Domains → Add Domain
# 2. Add the SPF record at your domain registrar:
#    Type: TXT  Host: @  Value: v=spf1 include:_spf.resend.com ~all
# 3. Add the DKIM record at your domain registrar:
#    Type: TXT  Host: resend._domainkey  Value: (provided by Resend dashboard)
# 4. Click "Verify" in the Resend dashboard — status must show "Verified"
# 5. Send a test email via Resend and confirm it arrives in your inbox (not spam)
#
# Domain verification is required; emails from unverified domains are
# likely to be flagged as spam or rejected outright.

# ── Approval Workflow ────────────────────────────────────────────────────
# Shared secret appended to approve/deny URLs for token validation (APPR-01).
# Generate with: openssl rand -base64 32
APPROVAL_SECRET=

# Public base URL for approval link generation in admin notification emails.
# Set to your Vercel deployment URL in production (e.g. https://your-app.vercel.app).
# For local development: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Admin Dashboard ──────────────────────────────────────────────────────
# Password for the admin dashboard login page (ADMIN-01).
ADMIN_PASSWORD=

# Secret for encrypting the admin session cookie (iron-session).
# MUST be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET=
